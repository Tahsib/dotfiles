# Pro SRE Ghostty Configuration
# Official Docs: ghostty +show-config --default --docs

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 12

# Theme (Catppuccin Mocha is built-in)
theme = Catppuccin Mocha

# --- BORDERLESS BUT DRAGGABLE ---
# Use true + hidden instead of false. 
# This looks borderless but lets you drag from the top 15-20 pixels.
window-decoration = true
macos-titlebar-style = hidden

# Padding (Matches your Pro Kitty setup)
window-padding-x = 12
window-padding-y = 12

# Transparency and Blur (Solid Background)
background-opacity = 1.0
background-blur-radius = 0

# Window Decorations (Square corners for macOS)
window-decoration = false
macos-titlebar-style = hidden

# Cursor
cursor-style = block
cursor-style-blink = true

# Mouse
mouse-hide-while-typing = true

# OS Tweaks (macOS)
macos-option-as-alt = left

# Terminal Features
shell-integration = zsh
copy-on-select = true

# Keybindings
keybind = cmd+enter=new_window
